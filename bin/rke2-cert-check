#!/usr/bin/env bash
# rke2-cert-check â€” report RKE2 certificate expiry on a remote node.
#
# Usage:
#   rke2-cert-check <host> [--user SSH_USER] [--warn DAYS] [--crit DAYS]
#
# Auto-detects server vs agent. Exit codes:
#   0  all certs OK
#   1  one or more certs within --warn days (default 60)
#   2  one or more certs within --crit days (default 14) or already expired
#   3  SSH / remote error

set -euo pipefail

WARN=60
CRIT=14
SSH_USER="${USER}"
HOST=""

while [ $# -gt 0 ]; do
  case "$1" in
    --user) SSH_USER="$2"; shift 2 ;;
    --warn) WARN="$2"; shift 2 ;;
    --crit) CRIT="$2"; shift 2 ;;
    -h|--help)
      sed -n '2,9p' "$0" | sed 's/^# \{0,1\}//'
      exit 0 ;;
    -*) echo "unknown flag: $1" >&2; exit 64 ;;
    *)  HOST="$1"; shift ;;
  esac
done

[ -z "$HOST" ] && { echo "usage: rke2-cert-check <host> [--user U] [--warn N] [--crit N]" >&2; exit 64; }

REMOTE='
set -e
shopt -s nullglob

role=agent
[ -d /var/lib/rancher/rke2/server/tls ] && role=server

echo "ROLE=$role"
echo "HOSTNAME=$(hostname)"

if [ "$role" = "server" ]; then
  systemctl show rke2-server --property=ActiveEnterTimestamp 2>/dev/null | sed "s/^/UPTIME_/"
else
  systemctl show rke2-agent  --property=ActiveEnterTimestamp 2>/dev/null | sed "s/^/UPTIME_/"
fi

paths=(
  /var/lib/rancher/rke2/agent/*.crt
)
if [ "$role" = "server" ]; then
  paths+=(
    /var/lib/rancher/rke2/server/tls/*.crt
    /var/lib/rancher/rke2/server/tls/etcd/*.crt
  )
fi

for f in "${paths[@]}"; do
  [ -f "$f" ] || continue
  end=$(openssl x509 -in "$f" -noout -enddate 2>/dev/null | cut -d= -f2) || continue
  [ -z "$end" ] && continue
  end_epoch=$(date -d "$end" +%s)
  printf "CERT\t%s\t%s\n" "$end_epoch" "$f"
done
'

OUT=$(ssh -o BatchMode=no -o ConnectTimeout=8 -t "${SSH_USER}@${HOST}" "sudo bash -c '$REMOTE'" 2>&1) || {
  echo "$OUT" >&2
  echo "rke2-cert-check: ssh/sudo failed on $HOST" >&2
  exit 3
}

# strip CR from `ssh -t`
OUT=$(printf "%s" "$OUT" | tr -d "\r")

ROLE=$(printf "%s\n" "$OUT" | awk -F= '/^ROLE=/{print $2; exit}')
RHOST=$(printf "%s\n" "$OUT" | awk -F= '/^HOSTNAME=/{print $2; exit}')
UPTIME=$(printf "%s\n" "$OUT" | awk -F= '/^UPTIME_ActiveEnterTimestamp=/{print $2; exit}')

if [ -t 1 ]; then
  R=$'\e[31m'; Y=$'\e[33m'; G=$'\e[32m'; D=$'\e[2m'; N=$'\e[0m'
else
  R=""; Y=""; G=""; D=""; N=""
fi

now=$(date +%s)
worst=0  # 0 ok, 1 warn, 2 crit

printf "%s  host=%s  role=%s  service-started=%s\n\n" "$HOST" "$RHOST" "$ROLE" "${UPTIME:-n/a}"
printf "%-45s %-25s %10s   %s\n" "CERT" "EXPIRES" "DAYS LEFT" "STATUS"
printf "%-45s %-25s %10s   %s\n" "----" "-------" "---------" "------"

printf "%s\n" "$OUT" | awk -F'\t' '$1=="CERT"{print $2"\t"$3}' | sort -n | while IFS=$'\t' read -r end_epoch path; do
  days=$(( (end_epoch - now) / 86400 ))
  end_str=$(date -d "@$end_epoch" "+%Y-%m-%d %H:%M %Z")
  name=$(basename "$path")
  case "$path" in
    */etcd/*) name="etcd/$name" ;;
  esac

  if [ "$days" -lt 0 ]; then
    status="${R}EXPIRED${N}"; level=2
  elif [ "$days" -le "$CRIT" ]; then
    status="${R}CRITICAL (<${CRIT}d)${N}"; level=2
  elif [ "$days" -le "$WARN" ]; then
    status="${Y}WARN (<${WARN}d)${N}"; level=1
  else
    status="${G}ok${N}"; level=0
  fi

  printf "%-45s %-25s %10d   %b\n" "$name" "$end_str" "$days" "$status"
  echo "$level" >> /tmp/.rke2cc.$$
done

if [ -f /tmp/.rke2cc.$$ ]; then
  worst=$(sort -n /tmp/.rke2cc.$$ | tail -1)
  rm -f /tmp/.rke2cc.$$
fi

echo
case "$worst" in
  0) echo "${G}all certs healthy${N}" ;;
  1) echo "${Y}some certs within ${WARN} days â€” schedule a rolling rke2 restart${N}" ;;
  2) echo "${R}critical: certs within ${CRIT} days or already expired${N}" ;;
esac

exit "$worst"
